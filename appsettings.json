{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },

  "Bitbucket": {
    "BaseUrl": "https://api.bitbucket.org/2.0",
    "Email": "",
    "ApiToken": "",
    "WebhookSecret": "",
    "ReviewableExtensions": [
      ".cs",
      ".ts",
      ".tsx",
      ".js",
      ".jsx",
      ".py",
      ".go",
      ".java",
      ".kt",
      ".rs",
      ".cpp",
      ".c",
      ".h",
      ".sql",
      ".yaml",
      ".yml"
    ],
    "MaxDiffCharsPerFile": 12000
  },

  "Anthropic": {
    "ApiKey": "",
    "Model": "claude-opus-4-6",
    "MaxTokens": 2048,
    "Temperature": 0.2,
    "PromptFilePath": "Prompts/CodeReviewPrompt.md"
  },

  "AllowedHosts": "*"
}
